{
  "name": "rekrutacja-kanban",
  "version": "1.0.0",
  "description": "Playwright TypeScript QA automation for the demo Kanban board application.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "clean:test-results": "node -e \"const fs=require('node:fs'); for (const dir of ['allure-results','test-results','playwright-report']) fs.rmSync(dir,{recursive:true,force:true})\"",
    "test:ci": "npm run clean:test-results && playwright test --project=chromium --grep-invert @performance",
    "test:performance": "npm run clean:test-results && playwright test --project=chromium --grep @performance --workers=1",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "report": "playwright show-report",
    "clean:allure-report": "node -e \"require('node:fs').rmSync('allure-report',{recursive:true,force:true})\"",
    "report:allure": "npm run clean:allure-report && allure awesome allure-results --output allure-report --history-path allure-history/history.jsonl",
    "report:allure:open": "allure open allure-report",
    "history:allure": "allure history allure-results --history-path allure-history/history.jsonl --history-limit 20 --report-name \"Kanban Recruitment QA\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "kanban"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "allure": "^3.8.2",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
